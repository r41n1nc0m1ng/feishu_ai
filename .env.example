# Feishu / Lark
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_CALENDAR_TARGET=app
FEISHU_CALENDAR_ID=

# OpenClaw server (leave empty to fall back to Ollama)
OPENCLAW_URL=

# Local LLM via Ollama
MODEL_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# OpenAI-compatible cloud model alternative.
# Set MODEL_PROVIDER=openai and fill these when Ollama is unavailable.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_EMBED_MODEL=

# Batch write side
# Default is 60 seconds for current P0 debugging and validation.
BATCH_POLL_INTERVAL=60
# P0 default: keep EvidenceBlock in local store and avoid Graphiti edge-extraction instability.
INDEX_EVIDENCE_IN_GRAPHITI=false

# P1-6 Event segmentation strategy
# time     (default) P0 time-gap + message-count thresholds, no external deps
# semantic           Embedding cosine-similarity segmentation; falls back to time on failure
SEGMENTER_STRATEGY=time
# Time gap (seconds) between adjacent messages that forces a new block (both strategies)
# Default 300s. Lower to 90 or 60 when messages are sent in rapid test sessions.
BLOCK_GAP_SECONDS=300
# Hard cap on messages per block (both strategies)
MAX_BLOCK_MESSAGES=30
# Cosine similarity below this value triggers a semantic block boundary (semantic mode only)
# 0.50 works better for different topics within the same project context
SEMANTIC_THRESHOLD=0.50
# Minimum messages in current block before a semantic cut is allowed
MIN_BLOCK_MESSAGES=3

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Neo4j (for Graphiti)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
