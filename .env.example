# Feishu / Lark
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenClaw server (leave empty to fall back to Ollama)
OPENCLAW_URL=

# Local LLM via Ollama
OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# Batch write side
# Product default is 10 minutes. Use 60 for local debugging if needed.
BATCH_POLL_INTERVAL=600

# Neo4j (for Graphiti)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
